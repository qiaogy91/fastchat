# -------- 常规配置 --------
SERVER_ENV=dev        # 当前开发环境
SERVER_NAME=fastchat  # 应用默认名称
SERVER_PORT=8000      # web服务器监听端口
SERVER_ADDR=0.0.0.0   # web服务器监听地址，0.0.0.0表示监听任意指向当前服务器的地址
SERVER_VERSION=v0.0.1 # 项目版本
SERVER_DEBUG=true     # 调试模式，true表示开启
SERVER_TIMEZONE=Asia/Shanghai  # 时区



# -------- 数据库配置 --------
DB_ADDR=127.0.0.1    # 数据库地址
DB_PORT=3306           # 数据库端口
DB_USERNAME=fastchat      # 用户名
DB_PASSWORD=fastchat   # 密码
DB_DATABASE=fastchat     # 数据库名
DB_CHARSET=utf8mb4      # 连接编码
DB_POOL_MINSIZE=10      # 连接池中的最小连接数
DB_POOL_MAXSIZE=30     # 连接池中的最大连接数
DB_ECHO=true            # 是否打印SQL 语句