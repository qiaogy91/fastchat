# -------- 常规配置 --------
SERVER__ENV=production
SERVER__NAME=MyApp
SERVER__ADDR=0.0.0.0
SERVER__PORT=8000
SERVER__DEBUG=false
SERVER__TIMEZONE=Asia/Shanghai
SERVER__VERSION=1.0.0

# -------- 日志配置 --------
LOGGER__LEVEL=20
LOGGER__ROOT='./logs'


# -------- 数据库配置 --------
DB__ADDR=127.0.0.1
DB__PORT=3306
DB__USERNAME=root
DB__PASSWORD=redhat
DB__DATABASE=fastchat
DB__CHATSET=utf8mb4
DB__POOL_MINSIZE=5
DB__POOL_MAXSIZE=20
DB__ECHO=true